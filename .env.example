# ============================================
# AutoWA Bot — Environment Variables
# ============================================
# Copy file ini jadi .env lalu isi dengan key kamu:
#   cp .env.example .env
#
# JANGAN commit file .env ke GitHub!
# ============================================

# ============================================
# Owner Configuration
# ============================================
# Nomor WhatsApp kamu (format: 628xxxxxxxxxx tanpa +)
OWNER_NUMBER=628xxxxxxxxxx
OWNER_NAME=NamaKamu

# ============================================
# Groq AI (Primary)
# ============================================
# Dapatkan dari: https://console.groq.com/keys
# Bisa isi banyak key untuk rotasi (anti rate-limit)
GROQ_API_KEY_1=gsk_your_key_here
# GROQ_API_KEY_2=gsk_your_key_here
# GROQ_API_KEY_3=gsk_your_key_here

# ============================================
# Gemini AI (Fallback / Opsional)
# ============================================
# Dapatkan dari: https://aistudio.google.com/apikey
# GEMINI_API_KEY_1=your_key_here
# GEMINI_API_KEY_2=your_key_here

# ============================================
# Server Configuration
# ============================================
PORT=3000
